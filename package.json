    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.20.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
